{
  "asyncapi": "2.6.0",
  "info": {
    "title": "Dota 2 Auction Draft — Socket.io Events",
    "version": "1.0.0",
    "description": "Real-time Socket.io events for the auction draft platform. All events are scoped to competition rooms (`comp:${compId}`)."
  },
  "servers": {
    "default": {
      "url": "localhost:3001",
      "protocol": "socket.io"
    }
  },
  "channels": {
    "auth": {
      "publish": {
        "summary": "Authenticate socket with session token (from handshake or explicit event)",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "token": { "type": "string", "description": "Bearer session token" }
            }
          },
          "examples": [
            {
              "name": "Authenticate",
              "payload": { "token": "abc123def456" }
            }
          ]
        }
      }
    },
    "auth:success": {
      "subscribe": {
        "summary": "Authentication confirmed",
        "message": { "payload": { "type": "null" } }
      }
    },
    "time:sync": {
      "publish": {
        "summary": "Request server time for clock sync",
        "message": { "payload": { "type": "null" } }
      },
      "subscribe": {
        "summary": "Server time response",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "serverTime": { "type": "integer", "description": "Unix timestamp in ms" }
            }
          },
          "examples": [
            {
              "name": "Server time",
              "payload": { "serverTime": 1710849600000 }
            }
          ]
        }
      }
    },
    "competition:join": {
      "publish": {
        "summary": "Join a competition room to receive real-time updates",
        "description": "Public competitions can be joined by anonymous sockets. Private (is_public=false) competitions require an authenticated socket — anonymous attempts receive `competition:join:denied` and the socket is not joined to the room.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "competitionId": { "type": "integer" }
            },
            "required": ["competitionId"]
          },
          "examples": [
            {
              "name": "Join competition 1",
              "payload": { "competitionId": 1 }
            }
          ]
        }
      }
    },
    "competition:join:denied": {
      "subscribe": {
        "summary": "Server rejected a competition:join attempt",
        "description": "Emitted only to the requesting socket (not broadcast). Currently sent when an anonymous socket tries to join a private competition.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "reason": { "type": "string", "enum": ["auth_required"] }
            },
            "required": ["reason"]
          }
        }
      }
    },
    "captain:ready": {
      "publish": {
        "summary": "Mark captain as ready to start draft",
        "description": "Requires captain role in current competition",
        "message": { "payload": { "type": "null" } }
      }
    },
    "captain:unready": {
      "publish": {
        "summary": "Mark captain as not ready",
        "message": { "payload": { "type": "null" } }
      }
    },
    "captains:ready": {
      "subscribe": {
        "summary": "Updated list of ready captain IDs",
        "message": {
          "payload": {
            "type": "array",
            "items": { "type": "integer" },
            "description": "Array of captain IDs that are ready"
          },
          "examples": [
            {
              "name": "Two captains ready",
              "payload": [3, 7]
            }
          ]
        }
      }
    },
    "match:ready": {
      "publish": {
        "summary": "Captain marks ready for a match game",
        "description": "When both captains are ready, lobby is auto-created if a bot is available",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "matchId": { "type": "integer" },
              "gameNumber": { "type": "integer" }
            },
            "required": ["matchId", "gameNumber"]
          },
          "examples": [
            {
              "name": "Ready for game 1 of match 5",
              "payload": { "matchId": 5, "gameNumber": 1 }
            }
          ]
        }
      }
    },
    "match:unready": {
      "publish": {
        "summary": "Captain unreadies for a match game",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "matchId": { "type": "integer" },
              "gameNumber": { "type": "integer" }
            },
            "required": ["matchId", "gameNumber"]
          },
          "examples": [
            {
              "name": "Unready for game 1 of match 5",
              "payload": { "matchId": 5, "gameNumber": 1 }
            }
          ]
        }
      }
    },
    "match:getReadyState": {
      "publish": {
        "summary": "Request current match ready state",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "matchId": { "type": "integer" },
              "gameNumber": { "type": "integer" }
            },
            "required": ["matchId", "gameNumber"]
          },
          "examples": [
            {
              "name": "Get ready state for game 2 of match 5",
              "payload": { "matchId": 5, "gameNumber": 2 }
            }
          ]
        }
      }
    },
    "match:joinRoom": {
      "publish": {
        "summary": "Join a match-specific socket room",
        "description": "Joins the match:${matchId} room for focused match updates. Used by the match room page.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "matchId": { "type": "integer" }
            },
            "required": ["matchId"]
          },
          "examples": [
            {
              "name": "Join match room",
              "payload": { "matchId": 5 }
            }
          ]
        }
      }
    },
    "match:leaveRoom": {
      "publish": {
        "summary": "Leave a match-specific socket room",
        "description": "Leaves the match:${matchId} room.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "matchId": { "type": "integer" }
            },
            "required": ["matchId"]
          },
          "examples": [
            {
              "name": "Leave match room",
              "payload": { "matchId": 5 }
            }
          ]
        }
      }
    },
    "match:readyState": {
      "subscribe": {
        "summary": "Broadcast match ready state for a game",
        "description": "Sent to competition room and match room when captains ready/unready. May include lobbyCreated or noBotAvailable flags.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "matchId": { "type": "integer" },
              "gameNumber": { "type": "integer" },
              "readyCaptainIds": { "type": "array", "items": { "type": "integer" } },
              "lobbyCreated": { "type": "boolean" },
              "noBotAvailable": { "type": "boolean" }
            }
          },
          "examples": [
            {
              "name": "Both captains ready, lobby created",
              "payload": { "matchId": 5, "gameNumber": 1, "readyCaptainIds": [3, 7], "lobbyCreated": true, "noBotAvailable": false }
            },
            {
              "name": "One captain ready",
              "payload": { "matchId": 5, "gameNumber": 1, "readyCaptainIds": [3], "lobbyCreated": false, "noBotAvailable": false }
            },
            {
              "name": "Both ready but no bot",
              "payload": { "matchId": 5, "gameNumber": 1, "readyCaptainIds": [3, 7], "lobbyCreated": false, "noBotAvailable": true }
            }
          ]
        }
      }
    },
    "captains:online": {
      "subscribe": {
        "summary": "Updated list of online captain IDs",
        "message": {
          "payload": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "examples": [
            {
              "name": "Three captains online",
              "payload": [3, 7, 12]
            }
          ]
        }
      }
    },
    "captains:updated": {
      "subscribe": {
        "summary": "Captain data changed (budget, status, etc.)",
        "message": {
          "payload": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "name": { "type": "string" },
                "team": { "type": "string" },
                "budget": { "type": "integer" },
                "status": { "type": "string" },
                "mmr": { "type": "integer" },
                "player_id": { "type": "integer" },
                "avatar_url": { "type": "string" },
                "banner_url": { "type": "string", "nullable": true }
              }
            }
          },
          "examples": [
            {
              "name": "Two captains with updated budgets",
              "payload": [
                { "id": 3, "name": "Puppey", "team": "Secret", "budget": 850, "status": "active", "mmr": 9500, "player_id": 10, "avatar_url": "https://cdn.example.com/puppey.jpg", "banner_url": "https://cdn.example.com/secret.png" },
                { "id": 7, "name": "N0tail", "team": "OG", "budget": 720, "status": "active", "mmr": 9200, "player_id": 15, "avatar_url": "https://cdn.example.com/notail.jpg", "banner_url": null }
              ]
            }
          ]
        }
      }
    },
    "players:updated": {
      "subscribe": {
        "summary": "Player pool data changed",
        "message": {
          "payload": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "name": { "type": "string" },
                "roles": { "type": "array", "items": { "type": "string" } },
                "mmr": { "type": "integer" },
                "drafted": { "type": "boolean" },
                "drafted_by": { "type": "integer", "nullable": true },
                "draft_price": { "type": "integer", "nullable": true }
              }
            }
          },
          "examples": [
            {
              "name": "Player pool after a draft pick",
              "payload": [
                { "id": 20, "name": "Miracle-", "roles": ["carry", "mid"], "mmr": 11000, "drafted": true, "drafted_by": 3, "draft_price": 250 },
                { "id": 21, "name": "GH", "roles": ["pos4"], "mmr": 9800, "drafted": false, "drafted_by": null, "draft_price": null }
              ]
            }
          ]
        }
      }
    },
    "settings:updated": {
      "subscribe": {
        "summary": "Competition settings changed",
        "message": {
          "payload": {
            "type": "object",
            "description": "Full CompSettings object"
          },
          "examples": [
            {
              "name": "Settings with bid timer and budget",
              "payload": { "startingBudget": 1000, "bidTimer": 15, "nomTimer": 30, "maxTeamSize": 5, "requireAllOnline": true, "blindBidding": false }
            }
          ]
        }
      }
    },
    "auction:start": {
      "publish": {
        "summary": "Start the draft (admin only)",
        "description": "Requires manage_auction permission. Needs ≥2 captains. If requireAllOnline, all captains must be ready.",
        "message": { "payload": { "type": "null" } }
      }
    },
    "auction:started": {
      "subscribe": {
        "summary": "Draft has started",
        "message": { "payload": { "type": "null" } }
      }
    },
    "auction:nominate": {
      "publish": {
        "summary": "Nominate a player for bidding",
        "description": "Only the current nominator (or admin) can nominate. Status must be 'nominating'.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "playerId": { "type": "integer", "description": "Player to nominate" },
              "startingBid": { "type": "integer", "description": "Optional custom starting bid" }
            },
            "required": ["playerId"]
          },
          "examples": [
            {
              "name": "Nominate player with default bid",
              "payload": { "playerId": 20 }
            },
            {
              "name": "Nominate player with custom starting bid",
              "payload": { "playerId": 20, "startingBid": 100 }
            }
          ]
        }
      }
    },
    "auction:bid": {
      "publish": {
        "summary": "Place an open bid",
        "description": "Only captains can bid. In post-blind open phase, only qualified top bidders can bid. Timer resets on each bid.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "amount": { "type": "integer", "description": "Bid amount in gold" }
            },
            "required": ["amount"]
          },
          "examples": [
            {
              "name": "Place a bid of 150 gold",
              "payload": { "amount": 150 }
            }
          ]
        }
      }
    },
    "auction:blind-bid": {
      "publish": {
        "summary": "Submit a sealed blind bid",
        "description": "Only during blind bidding phase. Captains can update their bid before timer expires. Timer does NOT reset.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "amount": { "type": "integer", "description": "Blind bid amount in gold" }
            },
            "required": ["amount"]
          },
          "examples": [
            {
              "name": "Submit blind bid of 200 gold",
              "payload": { "amount": 200 }
            }
          ]
        }
      }
    },
    "auction:blind-bid-confirmed": {
      "subscribe": {
        "summary": "Blind bid confirmation (private, sent only to the bidding socket)",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "amount": { "type": "integer" }
            }
          },
          "examples": [
            {
              "name": "Blind bid confirmed",
              "payload": { "amount": 200 }
            }
          ]
        }
      }
    },
    "auction:set-nominator": {
      "publish": {
        "summary": "Change the current nominator (admin only, while paused/nominating)",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "captainId": { "type": "integer", "description": "Captain ID to set as nominator" }
            },
            "required": ["captainId"]
          },
          "examples": [
            {
              "name": "Set captain 7 as nominator",
              "payload": { "captainId": 7 }
            }
          ]
        }
      }
    },
    "auction:recheck-order": {
      "publish": {
        "summary": "Recalculate nomination order (admin only, while paused/nominating)",
        "description": "Only available when nominationOrder is not 'normal' (round-robin). Recalculates who should nominate next based on the current nomination strategy.",
        "message": { "payload": { "type": "null" } }
      }
    },
    "auction:pause": {
      "publish": {
        "summary": "Pause the auction (admin only)",
        "message": { "payload": { "type": "null" } }
      }
    },
    "auction:resume": {
      "publish": {
        "summary": "Resume the auction (admin only)",
        "message": { "payload": { "type": "null" } }
      }
    },
    "auction:end": {
      "publish": {
        "summary": "End the draft immediately (admin only)",
        "message": { "payload": { "type": "null" } }
      }
    },
    "auction:undo": {
      "publish": {
        "summary": "Undo last nomination or sale (admin only)",
        "description": "During bidding: cancels current nomination. During nominating/finished: reverts last sold player.",
        "message": { "payload": { "type": "null" } }
      }
    },
    "auction:reset": {
      "publish": {
        "summary": "Reset entire draft state (admin only)",
        "description": "Resets all captains to starting budget, clears all drafted players, bid history, and auction logs.",
        "message": { "payload": { "type": "null" } }
      }
    },
    "auction:stateChanged": {
      "subscribe": {
        "summary": "Full auction state update — sent after every state change",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "status": { "type": "string", "enum": ["idle", "nominating", "bidding", "paused", "finished"] },
              "currentRound": { "type": "integer" },
              "totalRounds": { "type": "integer" },
              "nominator": { "type": "object", "nullable": true, "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "team": { "type": "string" } } },
              "nominatedPlayer": { "type": "object", "nullable": true },
              "currentBid": { "type": "integer" },
              "currentBidder": { "type": "object", "nullable": true, "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "team": { "type": "string" } } },
              "bidTimerEnd": { "type": "integer", "description": "Unix timestamp ms when timer expires" },
              "bidHistory": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "integer" }, "captain_id": { "type": "integer" }, "captain_name": { "type": "string" }, "amount": { "type": "integer" } } } },
              "blindPhase": { "type": "boolean" },
              "blindBidCount": { "type": "integer", "description": "Number of blind bids received (no amounts revealed)" },
              "topBidderIds": { "type": "array", "items": { "type": "integer" }, "description": "Captain IDs qualified from blind round" },
              "revealedBids": { "type": "array", "nullable": true, "items": { "type": "object", "properties": { "captainId": { "type": "integer" }, "captainName": { "type": "string" }, "amount": { "type": "integer" }, "qualified": { "type": "boolean" } } } },
              "captains": { "type": "array" },
              "players": { "type": "array" },
              "settings": { "type": "object" }
            }
          },
          "examples": [
            {
              "name": "Nominating phase — waiting for captain to pick a player",
              "payload": {
                "status": "nominating",
                "currentRound": 2,
                "totalRounds": 5,
                "nominator": { "id": 3, "name": "Puppey", "team": "Secret" },
                "nominatedPlayer": null,
                "currentBid": 0,
                "currentBidder": null,
                "bidTimerEnd": null,
                "bidHistory": [],
                "blindPhase": false,
                "blindBidCount": 0,
                "topBidderIds": [],
                "revealedBids": null,
                "captains": [],
                "players": [],
                "settings": {}
              }
            },
            {
              "name": "Active bidding on a player",
              "payload": {
                "status": "bidding",
                "currentRound": 2,
                "totalRounds": 5,
                "nominator": { "id": 3, "name": "Puppey", "team": "Secret" },
                "nominatedPlayer": { "id": 20, "name": "Miracle-", "mmr": 11000 },
                "currentBid": 180,
                "currentBidder": { "id": 7, "name": "N0tail", "team": "OG" },
                "bidTimerEnd": 1710849615000,
                "bidHistory": [
                  { "id": 1, "captain_id": 3, "captain_name": "Puppey", "amount": 100 },
                  { "id": 2, "captain_id": 7, "captain_name": "N0tail", "amount": 150 },
                  { "id": 3, "captain_id": 3, "captain_name": "Puppey", "amount": 180 }
                ],
                "blindPhase": false,
                "blindBidCount": 0,
                "topBidderIds": [],
                "revealedBids": null,
                "captains": [],
                "players": [],
                "settings": {}
              }
            },
            {
              "name": "Blind bidding phase — bids are sealed",
              "payload": {
                "status": "bidding",
                "currentRound": 1,
                "totalRounds": 5,
                "nominator": { "id": 3, "name": "Puppey", "team": "Secret" },
                "nominatedPlayer": { "id": 20, "name": "Miracle-", "mmr": 11000 },
                "currentBid": 0,
                "currentBidder": null,
                "bidTimerEnd": 1710849630000,
                "bidHistory": [],
                "blindPhase": true,
                "blindBidCount": 3,
                "topBidderIds": [],
                "revealedBids": null,
                "captains": [],
                "players": [],
                "settings": {}
              }
            },
            {
              "name": "Blind bids revealed — open phase begins for top bidders",
              "payload": {
                "status": "bidding",
                "currentRound": 1,
                "totalRounds": 5,
                "nominator": { "id": 3, "name": "Puppey", "team": "Secret" },
                "nominatedPlayer": { "id": 20, "name": "Miracle-", "mmr": 11000 },
                "currentBid": 250,
                "currentBidder": { "id": 7, "name": "N0tail", "team": "OG" },
                "bidTimerEnd": 1710849645000,
                "bidHistory": [],
                "blindPhase": false,
                "blindBidCount": 0,
                "topBidderIds": [3, 7],
                "revealedBids": [
                  { "captainId": 7, "captainName": "N0tail", "amount": 250, "qualified": true },
                  { "captainId": 3, "captainName": "Puppey", "amount": 240, "qualified": true },
                  { "captainId": 12, "captainName": "Kuroky", "amount": 100, "qualified": false }
                ],
                "captains": [],
                "players": [],
                "settings": {}
              }
            }
          ]
        }
      }
    },
    "auction:timerUpdate": {
      "subscribe": {
        "summary": "Bid timer updated",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "bidTimerEnd": { "type": "integer", "description": "Unix timestamp ms" }
            }
          },
          "examples": [
            {
              "name": "Timer reset after new bid",
              "payload": { "bidTimerEnd": 1710849615000 }
            }
          ]
        }
      }
    },
    "auction:sold": {
      "subscribe": {
        "summary": "Player sold to a captain",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "playerName": { "type": "string" },
              "captainName": { "type": "string" },
              "amount": { "type": "integer" }
            }
          },
          "examples": [
            {
              "name": "Player sold",
              "payload": { "playerName": "Miracle-", "captainName": "Puppey", "amount": 250 }
            }
          ]
        }
      }
    },
    "auction:finished": {
      "subscribe": {
        "summary": "Draft completed",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "results": { "type": "string" }
            }
          },
          "examples": [
            {
              "name": "Draft finished",
              "payload": { "results": "Draft completed successfully" }
            }
          ]
        }
      }
    },
    "auction:undone": {
      "subscribe": {
        "summary": "Undo action completed",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          },
          "examples": [
            {
              "name": "Last sale reverted",
              "payload": { "message": "Reverted sale of Miracle- to Secret for 250g" }
            }
          ]
        }
      }
    },
    "auction:log": {
      "subscribe": {
        "summary": "Activity log entry",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["start", "nomination", "bid", "sold", "pause", "resume", "undo", "end", "info"] },
              "message": { "type": "string" }
            }
          },
          "examples": [
            {
              "name": "Draft started",
              "payload": { "type": "start", "message": "Draft started" }
            },
            {
              "name": "Player nominated",
              "payload": { "type": "nomination", "message": "Puppey nominated Miracle- (starting bid: 100g)" }
            },
            {
              "name": "Bid placed",
              "payload": { "type": "bid", "message": "N0tail bid 150g on Miracle-" }
            },
            {
              "name": "Player sold",
              "payload": { "type": "sold", "message": "Miracle- sold to Secret for 250g" }
            },
            {
              "name": "Auction paused",
              "payload": { "type": "pause", "message": "Auction paused by admin" }
            }
          ]
        }
      }
    },
    "auction:logHistory": {
      "subscribe": {
        "summary": "Full auction log history (sent on room join)",
        "message": {
          "payload": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "message": { "type": "string" },
                "time": { "type": "integer" }
              }
            }
          },
          "examples": [
            {
              "name": "Log history with 3 entries",
              "payload": [
                { "type": "start", "message": "Draft started", "time": 1710849000000 },
                { "type": "nomination", "message": "Puppey nominated Miracle-", "time": 1710849010000 },
                { "type": "sold", "message": "Miracle- sold to Secret for 250g", "time": 1710849060000 }
              ]
            }
          ]
        }
      }
    },
    "auction:error": {
      "subscribe": {
        "summary": "Error message (private, sent only to the requesting socket)",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          },
          "examples": [
            {
              "name": "Insufficient budget",
              "payload": { "message": "Not enough budget to bid 500g (remaining: 350g)" }
            },
            {
              "name": "Not your turn",
              "payload": { "message": "It is not your turn to nominate" }
            }
          ]
        }
      }
    },
    "tournament:updated": {
      "subscribe": {
        "summary": "Tournament state changed (client should refetch)",
        "message": { "payload": { "type": "null" } }
      }
    },
    "news:updated": {
      "subscribe": {
        "summary": "News posts changed (global broadcast)",
        "message": { "payload": { "type": "null" } }
      }
    },
    "news:commented": {
      "subscribe": {
        "summary": "New comment on a news post (global broadcast)",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "newsId": { "type": "integer" }
            }
          },
          "examples": [
            {
              "name": "New comment on news post 42",
              "payload": { "newsId": 42 }
            }
          ]
        }
      }
    },
    "queue:kicked": {
      "subscribe": {
        "summary": "Private: admin kicked this socket's player out of their current queue. Client should reset queue state.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "poolId": { "type": "integer" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "queue:poolCounts": {
      "subscribe": {
        "summary": "Broadcast to all connected sockets: current queue size per pool. Fired on every join/leave so pool-selector badges stay in sync even for pools the client hasn't subscribed to.",
        "message": {
          "payload": {
            "type": "object",
            "additionalProperties": { "type": "integer", "description": "Queue size for the pool keyed by this property name (pool id)" },
            "description": "Object keyed by pool id (as string), value is the number of players currently waiting in that pool."
          }
        }
      }
    },
    "queue:getMyState": {
      "publish": {
        "summary": "Ask the server for this socket's current queue/match state. Used on app boot and page reload to restore the overlay and rejoin rooms.",
        "message": { "payload": { "type": "null" } }
      }
    },
    "queue:myState": {
      "subscribe": {
        "summary": "Private: the authenticated player's current queue/match state",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "inQueue": { "type": "boolean" },
              "poolId": { "type": "integer", "nullable": true },
              "poolName": { "type": "string", "nullable": true },
              "inMatch": { "type": "boolean" },
              "queueMatchId": { "type": "integer", "nullable": true },
              "count": { "type": "integer" },
              "players": { "type": "array", "items": { "type": "object" } },
              "ban": {
                "type": "object",
                "nullable": true,
                "description": "Active queue ban (if any). Null when the player is not banned.",
                "properties": {
                  "bannedUntil": { "type": "string", "format": "date-time", "nullable": true, "description": "ISO timestamp when the ban expires; null = permanent" },
                  "reason": { "type": "string", "nullable": true },
                  "bannedBy": { "type": "string", "nullable": true, "description": "Name of the admin who issued the ban; null when issued by the system (e.g. auto-ban for failing to join a lobby)" }
                }
              }
            }
          }
        }
      }
    },
    "queue:lobbyRetrying": {
      "subscribe": {
        "summary": "Broadcast: queue-match lobby creation failed with one bot and is being retried on a different one (queue-match:${queueMatchId}). Frontend should update the visible lobby name/password and show a transient retry notice.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "matchId": { "type": "integer" },
              "gameNumber": { "type": "integer" },
              "attempt": { "type": "integer", "description": "1-based attempt count" },
              "maxAttempts": { "type": "integer" },
              "lobbyInfo": {
                "type": "object",
                "properties": {
                  "gameName": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "queue:gameStarted": {
      "subscribe": {
        "summary": "Broadcast: Dota match ID captured for a queue match (queue-match:${queueMatchId}). Frontend should clear lobby banner.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "queueMatchId": { "type": "integer" },
              "dotaMatchId": { "type": "string" }
            }
          }
        }
      }
    },
    "queue:chatSend": {
      "publish": {
        "summary": "Send a chat message to a queue pool room (rate-limited to 1s per player)",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "poolId": { "type": "integer" },
              "text": { "type": "string", "maxLength": 300 }
            },
            "required": ["poolId", "text"]
          },
          "examples": [
            { "name": "Send chat", "payload": { "poolId": 1, "text": "anyone for 5v5?" } }
          ]
        }
      }
    },
    "queue:chatMessage": {
      "subscribe": {
        "summary": "Broadcast: chat message in a queue pool room (queue:${poolId})",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "poolId": { "type": "integer" },
              "playerId": { "type": "integer" },
              "name": { "type": "string" },
              "avatarUrl": { "type": "string", "nullable": true },
              "mmrVerifiedAt": { "type": "string", "format": "date-time", "nullable": true, "description": "Set if the sender has an admin-approved MMR verification (lets clients render the verified badge)" },
              "text": { "type": "string" },
              "ts": { "type": "integer", "description": "Unix timestamp ms" }
            }
          }
        }
      }
    },
    "queue:chatHistory": {
      "subscribe": {
        "summary": "Private: chat history sent to socket on queue:getState",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "poolId": { "type": "integer" },
              "messages": { "type": "array", "items": { "type": "object" } }
            }
          }
        }
      }
    },
    "queue:chatRateLimited": {
      "subscribe": {
        "summary": "Private: sender exceeded the 1s chat rate limit",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "retryAfterMs": { "type": "integer" }
            }
          }
        }
      }
    },
    "queue:readyCheck": {
      "subscribe": {
        "summary": "Broadcast to ready-check:${id}: a full pool has been pulled into a ready check. Client should show the Match Found modal with an Accept/Decline prompt and countdown to acceptTimerEnd.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "readyCheckId": { "type": "integer" },
              "poolId": { "type": "integer" },
              "players": { "type": "array", "items": { "type": "object" } },
              "acceptTimerEnd": { "type": "integer", "description": "Epoch ms deadline to Accept" },
              "acceptTimerSeconds": { "type": "integer", "description": "Configured accept window for this pool" },
              "expectedCount": { "type": "integer" }
            }
          }
        }
      }
    },
    "queue:readyCheckUpdate": {
      "subscribe": {
        "summary": "Broadcast to ready-check:${id}: accept/decline lists changed. Sent every time any player clicks Accept or Decline.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "readyCheckId": { "type": "integer" },
              "acceptedIds": { "type": "array", "items": { "type": "integer" } },
              "declinedIds": { "type": "array", "items": { "type": "integer" } },
              "expectedCount": { "type": "integer" }
            }
          }
        }
      }
    },
    "queue:readyCheckPassed": {
      "subscribe": {
        "summary": "Broadcast to ready-check:${id}: all players accepted; picking is starting. queue:matchFound will follow immediately.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "readyCheckId": { "type": "integer" }
            }
          }
        }
      }
    },
    "queue:readyCheckFailed": {
      "subscribe": {
        "summary": "Private: ready check ended without everyone accepting. reason='declined' if a player clicked Decline, 'timeout' if the window expired. requeued=true means this player accepted and was put back at the front of the pool queue; requeued=false means they were kicked out and (optionally) banned from queue for banMinutes.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "readyCheckId": { "type": "integer" },
              "reason": { "type": "string", "enum": ["declined", "timeout"] },
              "requeued": { "type": "boolean" },
              "banMinutes": { "type": "integer" }
            }
          }
        }
      }
    },
    "queue:accept": {
      "publish": {
        "summary": "Player accepts a ready check. Once all expected players have accepted, the server transitions to picking (queue:matchFound fires).",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "readyCheckId": { "type": "integer" }
            },
            "required": ["readyCheckId"]
          }
        }
      }
    },
    "queue:decline": {
      "publish": {
        "summary": "Player declines a ready check. Immediately ends the check for everyone — accepters are requeued, decliners are kicked (with optional queue ban per pool config).",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "readyCheckId": { "type": "integer" }
            },
            "required": ["readyCheckId"]
          }
        }
      }
    },
    "queue:setRolePreferences": {
      "publish": {
        "summary": "Participant in a queue match sets (or updates) their ordered role preferences. Server validates roles against ['carry','mid','offlane','support','hard_support'], dedupes, persists on queue_matches.role_preferences, and broadcasts queue:rolePreferencesUpdate to the queue-match room.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "queueMatchId": { "type": "integer" },
              "roles": {
                "type": "array",
                "description": "Ordered, deduped array of role keys. Index 0 = 1st choice, index 1 = 2nd, etc. Empty array clears the player's preferences.",
                "items": { "type": "string", "enum": ["carry", "mid", "offlane", "support", "hard_support"] }
              }
            },
            "required": ["queueMatchId", "roles"]
          }
        }
      }
    },
    "queue:lobbyCreated": {
      "subscribe": {
        "summary": "Broadcast to queue-match:${queueMatchId}: the Dota 2 lobby was created and is awaiting players. Client shows the Lobby Ready screen with credentials. Includes the initial players_joined snapshot (usually empty immediately after create).",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "queueMatchId": { "type": "integer" },
              "matchId": { "type": "integer" },
              "lobbyInfo": {
                "type": "object",
                "properties": {
                  "gameName": { "type": "string" },
                  "password": { "type": "string" }
                }
              },
              "lobbyExpiresAt": { "type": "integer", "description": "Epoch ms when the lobby auto-cancels if not enough players join" },
              "playersJoined": {
                "type": "array",
                "description": "Players currently in the Dota lobby. Each entry is an object with steamId/name/team as reported by the Go bot.",
                "items": {
                  "type": "object",
                  "properties": {
                    "steamId": { "type": "string" },
                    "name": { "type": "string" },
                    "team": { "type": "string", "enum": ["radiant", "dire"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "lobby:statusUpdate": {
      "subscribe": {
        "summary": "Broadcast to the lobby's rooms (queue-match or comp+match): the Go bot reported a change in lobby status or player-joined list. Client merges playersJoined into its state to render per-player 'In lobby / Not joined yet' badges.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "matchId": { "type": "integer" },
              "gameNumber": { "type": "integer" },
              "status": { "type": "string", "enum": ["creating", "waiting", "launching", "active", "completed", "error", "cancelled"] },
              "playersJoined": {
                "type": "array",
                "description": "Players currently in the Dota lobby. Each entry is an object with steamId/name/team as reported by the Go bot.",
                "items": {
                  "type": "object",
                  "properties": {
                    "steamId": { "type": "string" },
                    "name": { "type": "string" },
                    "team": { "type": "string", "enum": ["radiant", "dire"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "queue:rolePreferencesUpdate": {
      "subscribe": {
        "summary": "Broadcast to queue-match:${queueMatchId}: one participant's role preferences changed. Client should merge into its rolePreferences map keyed by playerId.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "queueMatchId": { "type": "integer" },
              "playerId": { "type": "integer" },
              "roles": {
                "type": "array",
                "items": { "type": "string", "enum": ["carry", "mid", "offlane", "support", "hard_support"] }
              }
            }
          }
        }
      }
    },
    "queue:liveStats": {
      "subscribe": {
        "summary": "Broadcast to queue-match:${queueMatchId}: realtime live-game snapshot polled from Steam GetRealtimeStats",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "queueMatchId":   { "type": "integer" },
              "radiant_score":  { "type": "integer", "nullable": true },
              "dire_score":     { "type": "integer", "nullable": true },
              "game_time":      { "type": "integer", "nullable": true, "description": "Steam game_time in seconds; negative during pre-game" },
              "game_state":     { "type": "integer", "nullable": true },
              "updated_at":     { "type": "integer", "description": "Unix ms when the snapshot was taken on the server" }
            }
          }
        }
      }
    },
    "home:liveStats": {
      "subscribe": {
        "summary": "Global broadcast: same payload as queue:liveStats — used by the homepage Live Matches strip to update scores in place without subscribing to per-match rooms",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "queueMatchId":   { "type": "integer" },
              "radiant_score":  { "type": "integer", "nullable": true },
              "dire_score":     { "type": "integer", "nullable": true },
              "game_time":      { "type": "integer", "nullable": true },
              "game_state":     { "type": "integer", "nullable": true },
              "updated_at":     { "type": "integer" }
            }
          }
        }
      }
    },
    "season:rankUpdated": {
      "subscribe": {
        "summary": "Broadcast: a season's rankings changed. Fired after a queue match completes (with the participating playerIds), after a manual admin point adjustment (with the affected playerId), or after a recompute (with recomputed: true). Clients with an open leaderboard or profile should refetch.",
        "message": {
          "payload": {
            "type": "object",
            "properties": {
              "seasonId": { "type": "integer" },
              "queueMatchId": { "type": "integer", "nullable": true },
              "playerIds": { "type": "array", "items": { "type": "integer" } },
              "recomputed": { "type": "boolean", "description": "true when the whole season was rebuilt" }
            },
            "required": ["seasonId"]
          }
        }
      }
    }
  }
}
